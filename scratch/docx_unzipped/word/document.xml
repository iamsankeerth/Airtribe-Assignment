<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mo="http://schemas.microsoft.com/office/mac/office/2008/main" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mv="urn:schemas-microsoft-com:mac:vml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 wp14"><w:body><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/><w:jc w:val="right"/></w:pPr><w:r><w:rPr><w:b/><w:color w:val="4B228A"/><w:sz w:val="20"/></w:rPr><w:t>Airtribe</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:b/><w:color w:val="4B228A"/><w:sz w:val="22"/></w:rPr><w:t>Backend Engineering Launchpad - Case Study</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Title"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/><w:jc w:val="center"/></w:pPr><w:r><w:t>Draftly: Gmail AI Reply Agent</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:color w:val="784CB9"/><w:sz w:val="21"/></w:rPr><w:t>Author: Airtribe</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:b/><w:sz w:val="56"/></w:rPr><w:t>Draftly</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>BACKGROUND</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Professionals spend hours each week drafting routine email replies such as confirmations, follow-ups, meeting responses, or polite acknowledgements. Automating these repetitive tasks can improve productivity and ensure consistency.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>This project will design and implement a backend for an AI-powered Gmail assistant that can generate and manage reply drafts on the user’s behalf, while giving the user full control before anything is sent.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>OBJECTIVE</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Build a reliable and extensible Gmail AI agent that can:</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Fetch incoming emails from a user’s Gmail inbox</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Generate draft replies using an AI model</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Learn from the user’s past email patterns to better match tone, phrasing, and style</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Allow review and approval before sending</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Send approved replies via Gmail with proper threading and metadata</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>KEY FEATURES</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Gmail Integration</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Connect securely using Gmail API with OAuth2</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Fetch unread or recent emails with metadata such as sender, subject, body, timestamp, and thread ID</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Draft Generation</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Use an AI model to generate reply drafts</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Support multiple tones such as formal, concise, or friendly</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Insert context from the existing thread and user preferences such as signature</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Learn from user’s last few sent emails to infer style, tone, and phrasing preferences</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Draft Review and Approval</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Provide APIs for users to view suggested drafts, approve, edit, or reject them</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Only approved drafts can be sent</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Reply Sending</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Send approved drafts via Gmail API</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Maintain thread integrity by using correct message IDs and headers</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Logging and History</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Store each draft and final sent email</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Track draft status such as approved, edited, or rejected</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Provide logs for monitoring and debugging</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Failure Handling</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="100" w:line="259" w:lineRule="auto"/></w:pPr><w:r><w:t>Retry failed sends automatically</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after